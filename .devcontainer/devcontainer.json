{
  "name": "NFT Contract",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.env"
  ],
  "mounts": [
    "type=bind,source=/run/host-services/ssh-auth.sock,target=/ssh-agent"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postStartCommand": "ngircd -f /etc/ngircd/ngircd.conf || true; nohup python3 ./scripts/irc-bot.py > /tmp/irc-bot.log 2>&1 &",

  "customizations": {
    "vscode": {
      "extensions": [
        "NomicFoundation.hardhat-solidity"
      ]
    }
  }
}
